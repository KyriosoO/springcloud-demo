<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dylan.mqConsumerServer.trans.mapper.TransactionLogArchiveMapper">

    <!-- ResultMap -->
    <resultMap id="TransactionLogArchiveResultMap" type="com.dylan.common.model.trans.TransactionLogArchive">
        <id property="transId" column="trans_id"/>
        <id property="seqNo" column="seq_no"/>
        <result property="payload" column="payload"/>
        <result property="processedAt" column="processed_at"/>
    </resultMap>

    <!-- 插入单条 -->
    <insert id="save" parameterType="com.dylan.common.model.trans.TransactionLogArchive">
        INSERT INTO transaction_log_archive (trans_id, seq_no, payload, processed_at)
        VALUES (#{transId}, #{seqNo}, #{payload}, #{processedAt})
    </insert>
</mapper>